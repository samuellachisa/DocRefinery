## LLM configuration (generic)
##
## Copy this file to `.env` and adjust values as needed.

# Backend: "openrouter" or "ollama"
LLM_BACKEND=ollama

# Base URL for the LLM API
# For Ollama (local default):
LLM_API_BASE=http://localhost:11434

# Text-only LLM model
LLM_TEXT_MODEL=llama3.2

# Vision-capable LLM model (for page image parsing). Must be multimodal, e.g. llama3.2-vision not llama3.2
LLM_VISION_MODEL=llama3.2-vision

# Timeout in seconds for vision API calls (default 600). Increase on slow GPUs or first run.
LLM_VISION_TIMEOUT_SEC=600

# For OpenRouter / OpenAI-compatible backends you would typically set:
# LLM_BACKEND=openrouter
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-your-key
# LLM_TEXT_MODEL=gpt-4o-mini
# LLM_VISION_MODEL=gpt-4o-mini

